# --- Database (matches docker-compose.yml; host port 5433 to avoid clashing with a local PG) ---
DATABASE_URL=postgres://arenaze:arenaze@localhost:5433/arenaze

# --- Server ---
PORT=4000
HOST=0.0.0.0
# CORS origin for the Vite dev server
WEB_ORIGIN=http://localhost:5173

# --- Auth (CHANGE THESE in any real deployment) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Seed demo credentials (printed by the seed script) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_STAFF_USERNAME=staff
SEED_STAFF_PASSWORD=staff123

# --- Web (Vite) ---
VITE_API_BASE=http://localhost:4000
